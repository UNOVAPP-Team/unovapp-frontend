<?xml version="1.0" encoding="utf-8"?>
<!--
    PlayerView configuré avec surface_type="texture_view".
    TextureView rend inline dans la hiérarchie View (contrairement à SurfaceView qui rend
    sur une couche séparée et peut produire le bug "double vidéo").

    Fond TRANSPARENT (background + shutter) : la vidéo est en mode "fit" (ratio préservé,
    entièrement visible) et le fond flouté placé DERRIÈRE le PlayerView (cf. VideoPlayer.kt)
    se voit dans les zones non couvertes → plein écran sans bandes noires, façon TikTok.
    Le resize_mode réel est forcé à FIT par programmation dans VideoPlayer.kt.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    app:surface_type="texture_view"
    app:resize_mode="fit"
    app:use_controller="false"
    app:shutter_background_color="@android:color/transparent" />
