    sarcelle + terracotta), converti depuis logo/symbol-color.svg.
    Remplace l'ancienne icône « play » générique qui n'avait rien d'UNOVAPP.
    Le contenu (26..74 du viewport 100) reste dans la zone sûre circulaire du masque splash.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group android:translateX="4" android:translateY="4">
        <path
            android:pathData="M26,52 L26,33 C26,28.6 28.6,26 33,26 L52,26"
            android:strokeColor="#0E6B6B"
            android:strokeWidth="14"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"/>
        <path
            android:pathData="M74,48 L74,67 C74,71.4 71.4,74 67,74 L48,74"
            android:strokeColor="#C65A2E"
            android:strokeWidth="14"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"/>
